# YouTube Data API v3 key (https://console.cloud.google.com → enable YouTube Data API v3 → create API key)
YOUTUBE_API_KEY=

# Cached resolved channel ID for @khalilgaming2020 (resolved once at startup if blank; set to skip the lookup)
YOUTUBE_CHANNEL_ID=

# Password for the /edit page. Pick something Khalil will remember.
EDIT_PASSWORD=

# GitHub commit settings — required for /edit to persist changes
# Fine-grained personal access token with "Contents: read+write" scoped to this repo only
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_BRANCH=main

# Signed session token for /edit (any long random string; rotate if exposed)
EDIT_SESSION_SECRET=
